S3_BUCKET=your-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Optional for S3-compatible providers such as MinIO, R2, or Backblaze.
S3_ENDPOINT=
S3_PATH_PREFIX=
S3_PUBLIC_BASE_URL=

# Scaleway Transactional Email configuration.
# The secret key is used as the X-Auth-Token to send emails via Scaleway's API.
SCALEWAY_EMAIL_REGION=fr-par
SCALEWAY_EMAIL_SECRET_KEY=your-scaleway-secret-key
SCALEWAY_EMAIL_PROJECT_ID=your-scaleway-project-id
SCALEWAY_EMAIL_FROM_EMAIL=noreply@your-domain.com
SCALEWAY_EMAIL_FROM_NAME=SpaceNix
# Set to 0 or false to disable sending verification emails.
SCALEWAY_EMAIL_ENABLED=1

# Admin credentials used to sign in before updating the S3 / email config.
SPACETIME_ADMIN_EMAIL=
SPACETIME_ADMIN_PASSWORD=

# Optional script overrides.
SPACETIME_SERVER=maincloud
SPACETIME_DATABASE=
