S3_BUCKET=your-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# Optional for S3-compatible providers such as MinIO, R2, or Backblaze.
S3_ENDPOINT=
S3_PATH_PREFIX=
S3_PUBLIC_BASE_URL=

# Admin credentials used to sign in before updating the S3 config.
SPACETIME_ADMIN_EMAIL=
SPACETIME_ADMIN_PASSWORD=

# Optional script overrides.
SPACETIME_SERVER=maincloud
SPACETIME_DATABASE=
